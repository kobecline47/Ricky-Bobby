# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Guild Configuration
GUILD_ID=your_guild_id_here

# Disboard Bump Webhook
# Get this from Disboard.org after setting up your server listing
DISBOARD_WEBHOOK_URL=https://disboard.org/api/v1/guilds/YOUR_GUILD_ID/bump

# Optional: Logging
LOG_CHANNEL_ID=your_log_channel_id_here

# Bump interval in hours (default: 2)
BUMP_INTERVAL_HOURS=2
